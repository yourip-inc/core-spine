# CODEOWNERS — YouRip Core Spine
#
# Story: T1-S1-G-02.
# Enforces that the Patent Conformance Officer (PCO) is a required reviewer
# on any PR touching patent-adjacent packages. Branch protection on `main`
# must enforce the CODEOWNERS rule; without that, this file is advisory only.
#
# Owner handle conventions:
#   @youripapp/pco          — Patent Conformance Officer team
#   @youripapp/engineering  — General engineering team (fallback)
#
# Order matters: later rules override earlier ones for the same path.

# Default owner for the whole repo.
*                                          @youripapp/engineering

# Patent-adjacent source packages. PCO required.
/src/canonical/                            @youripapp/pco @youripapp/engineering
/src/rubric/                               @youripapp/pco @youripapp/engineering
/src/rating/                               @youripapp/pco @youripapp/engineering
/src/challenge/                            @youripapp/pco @youripapp/engineering
/src/scoring/                              @youripapp/pco @youripapp/engineering
/src/migration/                            @youripapp/pco @youripapp/engineering
/src/submission/                           @youripapp/pco @youripapp/engineering
/src/errors/reason-codes.ts                @youripapp/pco @youripapp/engineering

# Migrations - any schema change on patent-adjacent tables is patent-adjacent.
/migrations/                               @youripapp/pco @youripapp/engineering

# Patent-adjacent tests.
/tests/unit/rubric-service.test.ts         @youripapp/pco @youripapp/engineering
/tests/unit/rating-service.test.ts         @youripapp/pco @youripapp/engineering
/tests/unit/challenge-service.test.ts      @youripapp/pco @youripapp/engineering
/tests/unit/canonical-json.test.ts         @youripapp/pco @youripapp/engineering
/tests/unit/scoring/                       @youripapp/pco @youripapp/engineering
/tests/unit/migration/                     @youripapp/pco @youripapp/engineering
/tests/unit/submission/                    @youripapp/pco @youripapp/engineering

# Registry + coverage machinery - PCO exclusive.
/tests/claim_registry.yaml                 @youripapp/pco
/src/claim-coverage/                       @youripapp/pco @youripapp/engineering

# Patent-conformance documents - PCO exclusive.
/docs/patent/                              @youripapp/pco
/docs/scoring-model-requirements.md        @youripapp/pco @youripapp/engineering
/docs/vocabulary-deprecations.md           @youripapp/pco @youripapp/engineering

# OpenAPI - schema changes carry API-contract weight.
/openapi/                                  @youripapp/pco @youripapp/engineering

# ESLint rules that enforce patent-conformance conventions.
/eslint-rules/                             @youripapp/pco @youripapp/engineering
