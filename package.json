{
  "name": "@yourip/core-spine",
  "version": "0.1.0",
  "private": true,
  "description": "YouRip T1 Core Spine — deterministic, signed, append-only event surface. Patent claims 1, 14, 21, 22, 23.",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/http/server.ts",
    "start": "node dist/http/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:claim-coverage": "vitest run tests/claim-coverage",
    "migrate": "tsx src/db/migrate.ts",
    "lint": "eslint --rulesdir eslint-rules src tests --ext .ts",
    "claim-coverage:report": "tsx src/claim-coverage/generate-report.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "fastify": "^4.27.0",
    "pg": "^8.11.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.5",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
